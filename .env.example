# =============================================================================
# CyanTrack — environment variables
# =============================================================================
#
# LOCAL (.env file):     copy this file to .env, use GOOGLE_CREDENTIALS_PATH
# RAILWAY (dashboard):   set variables in the UI — do NOT copy GOOGLE_CREDENTIALS_PATH
#                        use GOOGLE_CREDENTIALS_JSON instead (see Railway section below)
#
# =============================================================================

# --- Required (local + Railway) ---
BOT_TOKEN=
SPREADSHEET_ID=

# --- LOCAL ONLY — credentials file on your machine ---
# Not used on Railway (credentials.json is not deployed).
GOOGLE_CREDENTIALS_PATH=./credentials.json

# --- RAILWAY ONLY — paste credentials in the dashboard (not in this file) ---
# Add ONE of these in Railway → Variables (do not add GOOGLE_CREDENTIALS_PATH there):
#   GOOGLE_CREDENTIALS_JSON      — paste full credentials.json contents
#   GOOGLE_CREDENTIALS_JSON_B64  — one line from: uv run python scripts/encode_credentials.py

# --- Access control (recommended for production) ---
ALLOWED_USERS=

# --- Alerts (optional) ---
ALERT_CHAT_ID=

# --- Optional defaults ---
LOW_STOCK_THRESHOLD=20
DEFAULT_VOLUME=54000
DISPLAY_TZ=Africa/Accra
SPREADSHEET_NAME=CyanTrack Operations
INITIAL_STOCK=
