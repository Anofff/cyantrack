# Required
BOT_TOKEN=your_telegram_bot_token_from_botfather

# Optional — restrict write commands (arrival, treatment, restock)
# Comma-separated Telegram user IDs. Leave empty to allow everyone.
ALLOWED_USERS=

# Optional — group chat ID for arrival and low-stock alerts
ALERT_CHAT_ID=

# Optional — defaults
LOW_STOCK_THRESHOLD=20
DEFAULT_VOLUME=54000
DISPLAY_TZ=Africa/Accra

# Optional — auto-seed stock on bot startup when inventory is empty
INITIAL_STOCK=
