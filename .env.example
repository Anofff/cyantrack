# =============================================================================
# CyanTrack — environment variables
#
# Local:  copy to .env and fill in values
# Railway: set each variable in the service Variables tab (no .env file needed)
# =============================================================================

# --- Required ---
BOT_TOKEN=

# --- Google Sheets (required for production) ---
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SPREADSHEET_ID=

# Local dev — path to downloaded service account JSON
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Production (Railway) — paste the full service account JSON as the variable value.
# When set, this takes precedence over GOOGLE_CREDENTIALS_PATH.
# GOOGLE_CREDENTIALS_JSON=

# --- Access control (recommended for production) ---
# Comma-separated Telegram user IDs allowed to run write commands.
# Leave empty to allow all users.
ALLOWED_USERS=

# --- Alerts (optional) ---
# Numeric Telegram group/supergroup chat ID, e.g. -1001234567890
# Must be a real ID — placeholders like -100xxxxxxxxxx will be ignored.
ALERT_CHAT_ID=

# --- Optional defaults ---
LOW_STOCK_THRESHOLD=20
DEFAULT_VOLUME=54000
DISPLAY_TZ=Africa/Accra
SPREADSHEET_NAME=CyanTrack Operations

# Auto-seed hypochlorite buckets on startup when inventory is empty (pilot only)
INITIAL_STOCK=
